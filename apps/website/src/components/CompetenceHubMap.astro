---

<div class="hub-graph" data-hub-graph>
  <p class="visually-hidden" id="hub-graph-help">
    Der Competence Hub ist der zentrale Startknoten. Fokussieren oder berühren
    Sie den Kern, um seine Hauptverbindungen anzuzeigen. Die Außenknoten führen
    direkt zu den jeweiligen Bereichen.
  </p>

  <svg
    class="hub-graph__connections"
    viewBox="0 0 1200 760"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <circle class="hub-graph__orbit" cx="600" cy="380" r="188" />
    <circle class="hub-graph__orbit hub-graph__orbit--outer" cx="600" cy="380" r="310" />
    <circle class="hub-graph__marker" cx="600" cy="192" r="7" />
    {edges.map((edge) => (
      <path
        d={edge.d}
        data-edge
        data-from={edge.from}
        data-to={edge.to}
        pathLength="1"
      />
    ))}
  </svg>

  <div
    class="hub-graph__core"
    data-node="core"
    role="button"
    tabindex="0"
    aria-expanded="false"
    aria-describedby="hub-graph-help"
  >
    <span class="hub-graph__eyebrow">Zentraler Startknoten</span>
    <h1>Competence <em>Hub</em></h1>
    <p>Passende Expertise.<br />Persönlich verbunden.</p>
    <small>Verbindungen entdecken</small>
  </div>

  <nav class="hub-graph__nodes" aria-label="Bereiche des Competence Hub">
    {nodes.map((node) => (
      <span
        class={`hub-graph__position hub-graph__position--${node.kind}`}
        style={`--node-x: ${node.x}%; --node-y: ${node.y}%; --node-size: ${node.size}px;`}
      >
        <a
          class="hub-graph__node"
          data-node={node.id}
          data-kind={node.kind}
          href={url(node.href)}
          aria-label={`${node.title}: ${node.detail}`}
        >
          <Icon name={node.icon} size={node.kind === "primary" ? 25 : 20} />
          <strong>{node.title}</strong>
          <small>{node.detail}</small>
        </a>
      </span>
    ))}
  </nav>

  <div class="hub-graph__guide" aria-hidden="true">
    <span></span>
    <strong>Hub oder Knoten berühren</strong>
    <span></span>
  </div>
</div>

<script>
  const graphs = document.querySelectorAll<HTMLElement>("[data-hub-graph]");

  graphs.forEach((graph) => {
    const core = graph.querySelector<HTMLElement>('[data-node="core"]');
    const nodes = Array.from(
      graph.querySelectorAll<HTMLElement>(".hub-graph__node[data-node]"),
    );
    const edges = Array.from(
      graph.querySelectorAll<SVGPathElement>("[data-edge]"),
    );
    let locked = false;

    const clear = () => {
      graph.removeAttribute("data-active");
      core?.setAttribute("aria-expanded", "false");
      edges.forEach((edge) => edge.classList.remove("is-active"));
      nodes.forEach((node) => {
        node.classList.remove("is-active", "is-related", "is-muted");
      });
    };

    const activate = (id: string) => {
      clear();
      graph.dataset.active = id;
      core?.setAttribute("aria-expanded", id === "core" ? "true" : "false");

      const related = new Set<string>();
      edges.forEach((edge) => {
        const from = edge.dataset.from || "";
        const to = edge.dataset.to || "";
        const active =
          id === "core" ? from === "core" : from === id || to === id;

        edge.classList.toggle("is-active", active);
        if (active) {
          related.add(from);
          related.add(to);
        }
      });

      nodes.forEach((node) => {
        const nodeId = node.dataset.node || "";
        node.classList.toggle("is-active", nodeId === id);
        node.classList.toggle("is-related", related.has(nodeId));
        node.classList.toggle(
          "is-muted",
          id !== "core" && nodeId !== id && !related.has(nodeId),
        );
      });
    };

    const release = () => {
      if (locked) {
        activate("core");
      } else {
        clear();
      }
    };

    core?.addEventListener("mouseenter", () => activate("core"));
    core?.addEventListener("mouseleave", release);
    core?.addEventListener("focus", () => activate("core"));
    core?.addEventListener("blur", release);
    core?.addEventListener("click", () => {
      locked = !locked;
      locked ? activate("core") : clear();
    });
    core?.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        locked = !locked;
        locked ? activate("core") : clear();
      }
      if (event.key === "Escape") {
        locked = false;
        clear();
      }
    });

    nodes.forEach((node) => {
      const id = node.dataset.node || "";
      node.addEventListener("mouseenter", () => activate(id));
      node.addEventListener("mouseleave", release);
      node.addEventListener("focus", () => activate(id));
      node.addEventListener("blur", release);
    });
  });
</script>
