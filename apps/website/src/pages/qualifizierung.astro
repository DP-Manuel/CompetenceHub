---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title="Qualifizierung | Competence Hub"
  description="Archivierte Prototypseite: Qualifizierung ist eine moegliche spaetere Ausbaustufe, nicht Fokus des aktuellen Competence-Hub-MVP."
>
  <main class="subpage">
    <section class="page-hero">
      <p class="eyebrow">Spätere Ausbaustufe</p>
      <h1>Qualifizierung bleibt als Perspektive erhalten</h1>
      <p>
        Qualifizierung kann später ein Entwicklungsbaustein im Competence Hub
        werden. Für den Website-MVP stehen zunächst Livecoaching,
        Businesscoaching und ein klarer Anfrageweg im Vordergrund.
      </p>
      <div class="actions">
        <a class="button" href={url("leistungen")}>Zum aktuellen Angebot</a>
        <a class="button button--ghost" href={url("unternehmen")}>Für Unternehmen</a>
      </div>
    </section>
  </main>
</BaseLayout>
