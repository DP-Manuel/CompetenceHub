---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const later = [
  "Buchungssystem für Unternehmen und Coaches",
  "Coach-Kalender und mögliche Kalenderintegration",
  "Vertrags- und Anfrageprozesse",
  "App-Funktionen für spätere Aufträge, Termine und Rechnungen",
];
---

<BaseLayout
  title="Systemausblick | Competence Hub"
  description="Systemausblick fuer spaetere Competence-Hub-Ausbaustufen. Der aktuelle MVP enthaelt keine produktive App, keine Datenbank und keinen echten Login."
>
  <main class="subpage">
    <section class="page-hero page-hero--system">
      <p class="eyebrow">Spätere Ausbaustufe</p>
      <h1>Das spätere System ist nicht Teil des Website-MVP</h1>
      <p>
        Der aktuelle Competence-Hub-MVP ist eine statische Website. Buchung,
        Kalender, Datenbank, Verträge und App-Funktionen werden erst nach
        fachlicher und technischer Klärung umgesetzt.
      </p>
      <a class="button" href={url("kontakt")}>Website-Anfrage stellen</a>
    </section>

    <section class="module-board" aria-label="Spätere Systemmodule">
      {later.map((item) => <article>{item}</article>)}
    </section>
  </main>
</BaseLayout>
