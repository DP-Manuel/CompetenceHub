---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const occasions = [
  {
    title: "Führung und Zusammenarbeit",
    text: "Wenn Rollen, Verantwortung, Erwartungen oder Abstimmung im Team klarer werden sollen.",
  },
  {
    title: "Kommunikation",
    text: "Wenn Gespräche, Feedback, Kundenkontakt oder interne Abstimmung professioneller laufen sollen.",
  },
  {
    title: "Veränderung und Entwicklung",
    text: "Wenn neue Aufgaben, Wachstum, Umstrukturierung oder berufliche Entwicklung begleitet werden sollen.",
  },
  {
    title: "Belastung und Orientierung",
    text: "Wenn Teams Orientierung, Konfliktprävention und einen gesunden Umgang mit beruflicher Belastung brauchen.",
  },
  {
    title: "Qualifizierung als Baustein",
    text: "Wenn Coaching und Qualifizierung als Teil einer nachhaltigen Personal- und Kompetenzentwicklung gedacht werden.",
  },
];

const benefits = [
  "klare Einordnung des Anliegens",
  "passendes Coaching-Format statt Standardpaket",
  "kuratierte Auswahl statt unübersichtlichem Katalog",
  "passende Expertise für Thema und Unternehmenskontext",
];

const faqs = [
  {
    question: "Für welche Unternehmen eignet sich Competence Hub?",
    answer: "Für Unternehmen, die Führung, Zusammenarbeit, Kommunikation, Gesundheit oder berufliche Entwicklung gezielt begleiten möchten. Der erste Schritt ist eine Klärung von Zielgruppe, Anlass und gewünschtem Format.",
  },
  {
    question: "Ist das Angebot nur für Führungskräfte gedacht?",
    answer: "Nein. Führungskräfte sind eine wichtige Zielgruppe, aber auch Teams und Mitarbeitende in Veränderungs- oder Entwicklungssituationen können einbezogen werden.",
  },
  {
    question: "Gibt es garantierte Ergebnisse?",
    answer: "Nein. Coaching kann Reflexion, Orientierung und professionelle Entwicklung unterstützen, ersetzt aber keine unternehmerische Entscheidung und keine medizinische oder therapeutische Beratung.",
  },
];
---

<BaseLayout
  title="Coaching für Unternehmen | Competence Hub"
  description="Competence Hub vermittelt ausgewählte Coaches für Unternehmen in Führung, Zusammenarbeit, psychologischer Beratung, Gesundheit und Veränderung."
>
  <main class="subpage">
    <section class="page-hero">
      <p class="eyebrow">Für Unternehmen</p>
      <h1>Passende Coaches für echte Themen im Unternehmen</h1>
      <p>
        Competence Hub hilft Unternehmen, ihren Bedarf klar zu formulieren und
        vermittelt ausgewählte Coaches für das konkrete Thema, die Zielgruppe
        und den gewünschten Rahmen.
      </p>
      <div class="actions">
        <a class="button" href={url("kontakt")}>Bedarf besprechen</a>
        <a class="button button--ghost" href={url("leistungen")}>Formate vergleichen</a>
      </div>
    </section>

    <section class="feature-grid" aria-label="Typische Anlässe für Unternehmen">
      {occasions.map((occasion) => (
        <article class="feature-card">
          <h2>{occasion.title}</h2>
          <p>{occasion.text}</p>
        </article>
      ))}
    </section>

    <section class="split-panel">
      <div>
        <p class="eyebrow">Nutzen</p>
        <h2>Vom ersten Anliegen zur passenden Person</h2>
        <p>
          Unternehmen müssen nicht sofort wissen, welches Format richtig ist.
          Im ersten Schritt werden Anlass, Zielgruppe, Dringlichkeit und
          mögliche Formate sortiert und passende Expertise ausgewählt.
        </p>
      </div>
      <div class="benefit-grid">
        {benefits.map((benefit) => <span>{benefit}</span>)}
      </div>
    </section>

    <section class="faq-section" aria-labelledby="company-faq-title">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2 id="company-faq-title">Fragen von Unternehmen</h2>
      </div>
      <div class="faq-grid">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="cta-panel">
      <div>
        <p class="eyebrow">Nächster Schritt</p>
        <h2>Coaching-Bedarf kurz beschreiben</h2>
      </div>
      <a class="button" href={url("kontakt")}>Bedarf besprechen</a>
    </section>
  </main>
</BaseLayout>
