---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title="Seminare | Competence Hub"
  description="Archivierte Prototypseite: Der aktuelle Competence-Hub-MVP fokussiert auf Livecoaching und Businesscoaching."
>
  <main class="subpage">
    <section class="page-hero page-hero--accent">
      <p class="eyebrow">Archivierte Prototypseite</p>
      <h1>Seminare sind aktuell nicht der MVP-Fokus</h1>
      <p>
        Diese Seite bleibt aus Kompatibilitätsgründen erreichbar. Der aktuelle
        Competence-Hub-MVP konzentriert sich auf Livecoaching,
        Businesscoaching, Unternehmen, Coach-Netzwerk und Kontakt.
      </p>
      <div class="actions">
        <a class="button" href={url("leistungen")}>Aktuelle Leistungen ansehen</a>
        <a class="button button--ghost" href={url("kontakt")}>Anfrage stellen</a>
      </div>
    </section>
  </main>
</BaseLayout>
