---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const principles = [
  {
    title: "Passung vor Masse",
    text: "Coach, Thema, Zielgruppe und Format müssen zusammenpassen. Das Netzwerk soll Qualität sichtbar machen, nicht beliebig wachsen.",
  },
  {
    title: "Erfahrung und Haltung",
    text: "Für Unternehmen zählen fachliche Grundlage, Praxiserfahrung, Verlässlichkeit und ein professioneller Umgang mit sensiblen Anliegen.",
  },
  {
    title: "Klare Angebotslogik",
    text: "Jedes veröffentlichte Profil zeigt verständlich, welche Themen, Formate und Zielgruppen sinnvoll zusammengehören.",
  },
];

const coaches = [
  {
    name: "Christian Galvano",
    role: "Dozent, Fachtrainer und Coach",
    focus: [
      "Neuroleadership",
      "Konfliktmanagement",
      "Stress- und Burnoutprävention",
    ],
    text: "Christian Galvano verbindet neurowissenschaftliche Grundlagen mit praxisnahen Methoden für Führung, Kommunikation und gesundes Arbeiten.",
    profilePath: "coaches/christian-galvano",
    image: "images/coaches/christian-galvano.webp",
    initials: "CG",
  },
  {
    name: "Elisabeth Schwabauer",
    role: "Psychologin (M.Sc.)",
    focus: [
      "Psychologische Beratung",
      "Psychische Belastung",
      "Team- und Konfliktklärung",
    ],
    text: "Elisabeth Schwabauer verbindet psychologische Fachkenntnis mit Erfahrung in beruflicher Beratung, Teamprozessen und der Einordnung psychischer Belastungen.",
    profilePath: "coaches/elisabeth-schwabauer",
    initials: "ES",
  },
  {
    name: "Carolin Hupp",
    role: "Diplom-Sportwissenschaftlerin",
    focus: [
      "Betriebliche Gesundheit",
      "Bewegung und Prävention",
      "Entspannung und Balance",
    ],
    text: "Carolin Hupp bringt Gesundheits- und Trainingsmanagement, Bewegungsförderung und alltagstaugliche Prävention in Unternehmen und Gruppen zusammen.",
    profilePath: "coaches/carolin-hupp",
    initials: "CH",
  },
];
---

<BaseLayout
  title="Coach-Netzwerk | Competence Hub"
  description="Competence Hub vermittelt ausgewählte Coaches für Führung, Psychologie, Teamarbeit, Gesundheit und berufliche Entwicklung."
>
  <main class="subpage">
    <section class="page-hero page-hero--accent coach-list-hero">
      <div>
        <p class="eyebrow">Coach-Netzwerk</p>
        <h1>Ausgewählte Coaches statt endlosem Katalog</h1>
        <p>
          Bei Competence Hub stehen die Coaches und ihre Leistungen im
          Mittelpunkt. Wir verbinden Unternehmen mit Menschen, deren Erfahrung,
          Schwerpunkt und Arbeitsweise zum konkreten Anliegen passen.
        </p>
        <div class="actions">
          <a class="button" href={url("kontakt")}>Unternehmensbedarf besprechen</a>
          <a class="button button--ghost" href={url("kontakt")}>Als Coach vorstellen</a>
        </div>
      </div>
      <aside class="coach-list-hero__note" aria-label="Netzwerkanspruch">
        <span>Netzwerkanspruch</span>
        <strong>Passend.<br />Erfahren.<br />Verlässlich.</strong>
      </aside>
    </section>

    <section class="feature-grid" aria-label="Qualitätslogik im Coach-Netzwerk">
      {principles.map((principle) => (
        <article class="feature-card">
          <h2>{principle.title}</h2>
          <p>{principle.text}</p>
        </article>
      ))}
    </section>

    <section class="coach-grid" aria-label="Vorhandene Coach-Profile">
      {coaches.map((coach) => (
        <article class="coach-card coach-card--featured">
          <div class="coach-card__media">
            {coach.image ? (
              <img
                src={url(coach.image)}
                alt={`Porträt von ${coach.name}`}
                width="830"
                height="830"
                loading="lazy"
              />
            ) : (
              <span class="coach-card__monogram" aria-hidden="true">{coach.initials}</span>
            )}
          </div>
          <div>
            <p class="eyebrow">Coach-Profil</p>
            <h2>{coach.name}</h2>
            <strong>{coach.role}</strong>
            <ul class="tag-list" aria-label="Themenschwerpunkte">
              {coach.focus.map((topic) => <li>{topic}</li>)}
            </ul>
            <p>{coach.text}</p>
            <a class="button button--ghost" href={url(coach.profilePath)}>
              Profil ansehen
            </a>
          </div>
        </article>
      ))}
    </section>

    <section class="network-growth-note" aria-labelledby="network-growth-title">
      <p class="eyebrow">Netzwerk im Aufbau</p>
      <h2 id="network-growth-title">Das Netzwerk wächst bewusst</h2>
      <p>
        Weitere Profile werden ergänzt, sobald Schwerpunkte, Qualifikationen,
        Texte und Bildfreigaben abgestimmt sind. Qualität und Passung bleiben
        wichtiger als die reine Anzahl.
      </p>
    </section>

    <section class="cta-panel">
      <div>
        <p class="eyebrow">Kontakt</p>
        <h2>Coach-Profil oder Unternehmensbedarf besprechen</h2>
      </div>
      <a class="button" href={url("kontakt")}>Bedarf besprechen</a>
    </section>
  </main>
</BaseLayout>
