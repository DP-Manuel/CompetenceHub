---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const primaryEmail = "competencehub@donner-partner.de";
const testEmail = "roedel.kg@donner-partner.eu";
const showTestContact = import.meta.env.DEV;

const subject = encodeURIComponent("Anfrage über Competence Hub");
const body = encodeURIComponent(
  "Unternehmen / Organisation:\nAnliegen:\nZielgruppe:\nGewünschter Zeitraum:\nRückrufnummer (optional):\n",
);
const mailto = (email: string) =>
  `mailto:${email}?subject=${subject}&body=${body}`;

const requestSteps = [
  "Anliegen und Zielgruppe kurz beschreiben",
  "gewünschten Zeitraum nennen",
  "Kontaktdaten für die Rückmeldung ergänzen",
];

const helpfulDetails = [
  "Unternehmen oder Organisation",
  "beruflicher Anlass und gewünschte Wirkung",
  "Zielgruppe oder ungefähre Teilnehmendenzahl",
  "gewünschter Zeitraum oder Dringlichkeit",
];
---

<BaseLayout
  title="Kontakt und Anfrage | Competence Hub"
  description="Kontakt zu Competence Hub für Livecoaching, Businesscoaching und Coaching-Anfragen von Unternehmen, Führungskräften und Teams."
>
  <main class="subpage">
    <section class="contact-page">
      <div>
        <p class="eyebrow">Kontakt</p>
        <h1>Ihr Anliegen ist der beste Ausgangspunkt</h1>
        <p>
          Sie müssen noch nicht wissen, welches Coaching-Format passt.
          Beschreiben Sie kurz die berufliche Situation, die Zielgruppe und
          den gewünschten nächsten Schritt. Wir melden uns zur gemeinsamen
          Einordnung zurück.
        </p>
        <div class="login-preview-list" aria-label="Anfrage vorbereiten">
          {requestSteps.map((step) => <span>{step}</span>)}
        </div>
        <a class="button" href={mailto(primaryEmail)}>E-Mail-Anfrage öffnen</a>
      </div>

      <aside class="contact-options" aria-labelledby="direct-contact-title">
        <p class="eyebrow">Direkter Kontakt</p>
        <h2 id="direct-contact-title">Per E-Mail an Competence Hub</h2>
        <a class="contact-email" href={mailto(primaryEmail)}>{primaryEmail}</a>
        <p>
          Der Link öffnet Ihr E-Mail-Programm mit einer kurzen Vorlage. Auf
          dieser Website werden dabei keine Formulardaten erfasst.
        </p>

        <div class="contact-checklist">
          <strong>Hilfreich für eine schnelle Einordnung</strong>
          <ul>
            {helpfulDetails.map((detail) => <li>{detail}</li>)}
          </ul>
        </div>

        {showTestContact && (
          <div class="contact-test-note">
            <strong>Lokaler Testkontakt</strong>
            <p>
              Diese Adresse ist nur im Entwicklungsmodus sichtbar und wird
              nicht in den Produktions-Build übernommen.
            </p>
            <a href={mailto(testEmail)}>{testEmail}</a>
          </div>
        )}
      </aside>
    </section>
  </main>
</BaseLayout>
