---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const requestSteps = [
  "Anliegen kurz beschreiben",
  "Interesse und Zielgruppe einordnen",
  "passenden nächsten Kontakt vorbereiten",
];
---

<BaseLayout
  title="Kontakt und Anfrage | Competence Hub"
  description="Kontakt zu Competence Hub fuer Anfragen zu Livecoaching, Businesscoaching, Coaching fuer Unternehmen und Coach-Netzwerk."
>
  <main class="subpage">
    <section class="contact-page">
      <div>
        <p class="eyebrow">Kontakt</p>
        <h1>Anfrage zu Coaching und Coach-Netzwerk</h1>
        <p>
          Beschreiben Sie kurz, worum es geht. Das Formular ist im MVP noch
          statisch und sendet keine Daten. Die technische Anbindung wird vor
          Livegang sicher konfiguriert.
        </p>
        <div class="login-preview-list" aria-label="Anfrageablauf">
          {requestSteps.map((step) => <span>{step}</span>)}
        </div>
      </div>
      <form class="contact-form" aria-label="Kontaktformular Demo">
        <label>
          Name
          <input name="name" type="text" placeholder="Vor- und Nachname" />
        </label>
        <label>
          Unternehmen
          <input name="company" type="text" placeholder="Unternehmen oder Organisation" />
        </label>
        <label>
          E-Mail
          <input name="email" type="email" placeholder="name@unternehmen.de" />
        </label>
        <label>
          Anliegen
          <select name="interest">
            <option>Livecoaching</option>
            <option>Businesscoaching</option>
            <option>Coaching für Unternehmen</option>
            <option>Coach-Netzwerk</option>
          </select>
        </label>
        <label class="contact-form__wide">
          Nachricht
          <textarea
            name="message"
            rows="5"
            placeholder="Was ist der Anlass, wer ist beteiligt, welcher nächste Schritt wäre hilfreich?"
          ></textarea>
        </label>
        <p class="form-note contact-form__wide">
          Demo-Status: Dieses Formular ist noch nicht angebunden und speichert
          oder versendet keine Daten.
        </p>
        <button class="button contact-form__wide" type="button">Anfrage vorbereiten</button>
      </form>
    </section>
  </main>
</BaseLayout>
