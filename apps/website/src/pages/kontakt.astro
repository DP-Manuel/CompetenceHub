---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import "../styles/global.css";

const primaryEmail = "competencehub@donner-partner.de";
const fallbackSubject = encodeURIComponent("Anfrage über Competence Hub");
const fallbackMailto = `mailto:${primaryEmail}?subject=${fallbackSubject}`;

const topics = [
  "Livecoaching",
  "Businesscoaching",
  "Psychologische Beratung & Prävention",
  "Supervision, Workshop oder Vortrag",
  "Recruiting & Personalentwicklung",
  "Coach-Auswahl",
  "Noch nicht sicher",
];
---

<BaseLayout
  title="Kontakt und Anfrage | Competence Hub"
  description="Kontakt zu Competence Hub für Livecoaching, Businesscoaching und Coaching-Anfragen von Unternehmen, Führungskräften und Teams."
>
  <main class="subpage">
    <section class="contact-page">
      <div class="contact-page__intro">
        <p class="eyebrow">Kontakt</p>
        <h1>Lassen Sie uns über Ihr Anliegen sprechen.</h1>
        <p>
          Ein paar Stichpunkte reichen. Wir melden uns zur gemeinsamen
          Einordnung und empfehlen den passenden nächsten Schritt.
        </p>
        <div class="contact-points" aria-label="So geht es weiter">
          <span><Icon name="message-circle" size={22} /> Anliegen schildern</span>
          <span><Icon name="user-round" size={22} /> Expertise auswählen</span>
          <span><Icon name="calendar" size={22} /> Rahmen abstimmen</span>
        </div>
        <aside class="contact-person" aria-label="Persönliche Ansprechpartnerin">
          <span aria-hidden="true"><Icon name="user-round" size={30} /></span>
          <div>
            <small>Ihre Ansprechpartnerin</small>
            <strong>Janay Rappelt</strong>
            <p>
              Sie verbindet Ihr Unternehmensanliegen mit der passenden
              Coach-Expertise und begleitet die Abstimmung.
            </p>
          </div>
        </aside>
        <a class="contact-email" href={fallbackMailto}>{primaryEmail}</a>
      </div>

      <form
        class="contact-form"
        id="contact-request-form"
        data-recipient={primaryEmail}
      >
        <div class="contact-form__heading contact-form__wide">
          <p class="eyebrow">Anfrage vorbereiten</p>
          <h2>Worum geht es?</h2>
        </div>

        <label>
          Unternehmen
          <input name="company" autocomplete="organization" required />
        </label>

        <label>
          Ansprechpartner:in
          <input name="contact" autocomplete="name" required />
        </label>

        <label class="contact-form__wide">
          E-Mail-Adresse
          <input name="email" type="email" autocomplete="email" required />
        </label>

        <label class="contact-form__wide">
          Thema
          <select name="topic" required>
            <option value="">Bitte auswählen</option>
            {topics.map((topic) => <option value={topic}>{topic}</option>)}
          </select>
        </label>

        <label class="contact-form__wide">
          Anliegen
          <textarea
            name="message"
            rows="5"
            placeholder="Situation, Zielgruppe und gewünschter Zeitraum"
            required
          ></textarea>
        </label>

        <button class="button contact-form__wide" type="submit">
          E-Mail-Anfrage vorbereiten
        </button>
        <p class="form-note contact-form__wide">
          Der Button öffnet Ihr E-Mail-Programm. Die Website speichert keine Formulardaten.
        </p>
      </form>
    </section>
  </main>

  <script>
    const form = document.querySelector<HTMLFormElement>("#contact-request-form");

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const recipient = form.dataset.recipient;
      const topic = String(data.get("topic") || "Coaching-Anfrage");
      const body = [
        `Unternehmen: ${data.get("company") || ""}`,
        `Ansprechpartner:in: ${data.get("contact") || ""}`,
        `E-Mail: ${data.get("email") || ""}`,
        `Thema: ${topic}`,
        "",
        String(data.get("message") || ""),
      ].join("\n");

      window.location.href = `mailto:${recipient}?subject=${encodeURIComponent(`Anfrage: ${topic}`)}&body=${encodeURIComponent(body)}`;
    });
  </script>
</BaseLayout>
