---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const futureItems = [
  "geschützte Buchungs- und Verwaltungsbereiche",
  "Coach-Kalender und Auftragsübersicht",
  "Anfragen, Angebote und Vertragsprozesse",
  "mobile Nutzung für spätere operative Abläufe",
];
---

<BaseLayout
  title="Login | Competence Hub"
  description="Der Login ist eine spaetere Ausbaustufe. Der aktuelle Competence-Hub-MVP enthaelt keine produktiven Accounts."
  bodyClass="login-page"
>
  <main class="login-shell">
    <section class="login-panel">
      <div class="login-copy">
        <p class="eyebrow">Nicht produktiv</p>
        <h1>Ein echter Login ist noch nicht Teil des Website-MVP</h1>
        <p>
          Competence Hub startet mit einer statischen Website für Angebote,
          Unternehmen, Coach-Netzwerk und Kontakt. Geschützte Bereiche,
          Accounts, Datenbank und Buchungsfunktionen werden erst später
          fachlich und technisch geplant.
        </p>
        <div class="login-preview-list">
          {futureItems.map((item) => <span>{item}</span>)}
        </div>
      </div>

      <aside class="login-card" aria-label="Status des Login-Bereichs">
        <span class="demo-badge">Ausbaustufe</span>
        <h2>Kein Login aktiv</h2>
        <p>
          Es gibt hier keine produktive Anmeldung, keine Testzugänge, keine
          Datenbank und keine personenbezogene Datenerfassung.
        </p>
      </aside>
    </section>
  </main>
</BaseLayout>
