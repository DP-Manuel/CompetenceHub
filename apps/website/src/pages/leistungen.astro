---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const services = [
  {
    eyebrow: "Livecoaching",
    title: "Konkrete Situationen klären",
    text: "Für Gespräche, Entscheidungen, Konflikte und Rollenfragen.",
    href: "livecoaching",
    id: undefined,
    icon: "message-circle" as const,
  },
  {
    eyebrow: "Businesscoaching",
    title: "Entwicklung gezielt begleiten",
    text: "Für Führung, Zusammenarbeit und berufliche Entwicklung.",
    href: "businesscoaching",
    id: undefined,
    icon: "briefcase" as const,
  },
  {
    eyebrow: "Recruiting & Personalentwicklung",
    title: "Potenziale passend verbinden",
    text: "Für Mitarbeitergewinnung, Führung und Entwicklung mit Blick auf praktische Fähigkeiten und Unternehmensbedarf.",
    href: "kontakt",
    id: "recruiting",
    icon: "building" as const,
  },
  {
    eyebrow: "Psychologische Beratung",
    title: "Belastungen fundiert einordnen",
    text: "Für Prävention und psychologische Fragen im beruflichen Kontext.",
    href: "kontakt",
    id: "gesundheit",
    icon: "heart-pulse" as const,
  },
  {
    eyebrow: "Supervision, Workshops & Vorträge",
    title: "Teams gemeinsam weiterbringen",
    text: "Für Reflexion, Wissenstransfer und Lernimpulse in Gruppen.",
    href: "kontakt",
    id: "gruppenformate",
    icon: "users" as const,
  },
];

const faqs = [
  {
    question: "Was ist der Unterschied zwischen Livecoaching und Businesscoaching?",
    answer: "Livecoaching ist besonders nah an konkreten Situationen. Businesscoaching ist breiter angelegt und begleitet Führung, Zusammenarbeit, Rollenklärung oder berufliche Entwicklung strukturiert.",
  },
  {
    question: "Können Teams und Einzelpersonen im beruflichen Kontext begleitet werden?",
    answer: "Ja. Das Angebot richtet sich an Unternehmen, Teams, Führungskräfte und Mitarbeitende, wenn das Anliegen beruflich eingeordnet ist.",
  },
  {
    question: "Wie startet eine Anfrage?",
    answer: "Über die Kontaktseite werden Anlass, Zielgruppe, gewünschter Schwerpunkt und Zeitraum per E-Mail beschrieben. Danach wird der passende nächste Schritt gemeinsam geklärt.",
  },
  {
    question: "Erbringt Competence Hub die Leistungen selbst?",
    answer: "Competence Hub klärt den Bedarf und vermittelt passende Coaches oder Expertinnen und Experten aus dem Netzwerk. Durchführung, Umfang und Rahmen werden anschließend transparent abgestimmt.",
  },
  {
    question: "Gehört Recruiting bereits zum Angebot?",
    answer: "Recruiting und Personalentwicklung werden in der lokalen Konzeptversion als ergänzendes Feld berücksichtigt. Der konkrete Leistungsumfang wird im Erstkontakt geklärt und vor einer öffentlichen Vermarktung fachlich finalisiert.",
  },
];
---

<BaseLayout
  title="Leistungen | Competence Hub"
  description="Competence Hub verbindet Unternehmen mit Expertise für Livecoaching, Businesscoaching, Recruiting, psychologische Beratung, Supervision, Workshops und Vorträge."
>
  <main class="subpage">
    <section class="page-hero page-hero--accent">
      <p class="eyebrow">Leistungen</p>
      <h1>Das Thema zuerst. Dann die passende Expertise.</h1>
      <p>
        Competence Hub klärt den Bedarf und vermittelt ausgewählte Coaches
        oder Expertinnen und Experten. So finden Unternehmen einen passenden
        Einstieg, ohne sich zuerst durch einen großen Katalog arbeiten zu müssen.
      </p>
      <div class="actions">
        <a class="button" href={url("kontakt")}>Anfrage stellen</a>
        <a class="button button--ghost" href={url("unternehmen")}>Für Unternehmen</a>
      </div>
    </section>

    <section class="offer-grid" aria-label="Angebotsübersicht">
      {services.map((service) => (
        <article class="offer-card" id={service.id}>
          <span class="offer-card__icon"><Icon name={service.icon} size={30} /></span>
          <p class="eyebrow">{service.eyebrow}</p>
          <h2>{service.title}</h2>
          <p>{service.text}</p>
          <a class="text-link" href={url(service.href)}>Mehr erfahren</a>
        </article>
      ))}
    </section>

    <section class="cta-panel">
      <div>
        <p class="eyebrow">Noch unsicher?</p>
        <h2>Wir ordnen Ihr Anliegen gemeinsam ein.</h2>
        <p>Eine kurze Beschreibung reicht für eine erste Empfehlung.</p>
      </div>
      <a class="button" href={url("kontakt")}>Bedarf klären</a>
    </section>

    <section class="faq-section" aria-labelledby="services-faq-title">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2 id="services-faq-title">Häufige Fragen zu den Leistungen</h2>
      </div>
      <div class="faq-grid">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
