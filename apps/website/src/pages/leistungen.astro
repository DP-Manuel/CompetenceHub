---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const services = [
  {
    eyebrow: "Livecoaching",
    title: "Direkt an konkreten Situationen arbeiten",
    text: "Livecoaching passt, wenn ein berufliches Anliegen nah an einer realen Situation begleitet werden soll: Gespräche, Führung, Konflikte, Rollen oder Veränderung.",
    href: "livecoaching",
    id: undefined,
  },
  {
    eyebrow: "Businesscoaching",
    title: "Entwicklung strukturiert begleiten",
    text: "Businesscoaching eignet sich für Unternehmen, Führungskräfte, Teams und Mitarbeitende, die Ziele, Zusammenarbeit und berufliche Entwicklung systematisch klären möchten.",
    href: "businesscoaching",
    id: undefined,
  },
  {
    eyebrow: "Psychologische Beratung",
    title: "Berufliche Belastungen fundiert einordnen",
    text: "Für Vorgesetzte, Selbstständige, Teams und Mitarbeitende bei psychischen Belastungen und psychologischen Fragestellungen im Arbeitskontext.",
    href: "kontakt",
    id: "gesundheit",
  },
  {
    eyebrow: "Supervision, Workshops & Vorträge",
    title: "Gemeinsam reflektieren und Wissen anwenden",
    text: "Für Teams und Gruppen, wenn fachliche Reflexion, Prävention oder ein praxisnaher Lernimpuls im Mittelpunkt steht.",
    href: "kontakt",
    id: undefined,
  },
];

const comparison = [
  {
    title: "Livecoaching",
    text: "situationsnah, konkret, häufig direkt an einem aktuellen beruflichen Anlass ausgerichtet",
  },
  {
    title: "Businesscoaching",
    text: "strukturiert, entwicklungsorientiert, passend für Führung, Teams und Veränderungsprozesse",
  },
  {
    title: "Psychologische Beratung",
    text: "fachlich fundiert, berufsbezogen und klar von Psychotherapie oder medizinischer Behandlung abgegrenzt",
  },
  {
    title: "Supervision, Workshop oder Vortrag",
    text: "für gemeinsame Reflexion, Wissenstransfer und konkrete Impulse in Teams oder größeren Gruppen",
  },
];

const faqs = [
  {
    question: "Was ist der Unterschied zwischen Livecoaching und Businesscoaching?",
    answer: "Livecoaching ist besonders nah an konkreten Situationen. Businesscoaching ist breiter angelegt und begleitet Führung, Zusammenarbeit, Rollenklärung oder berufliche Entwicklung strukturiert.",
  },
  {
    question: "Können Teams und Einzelpersonen im beruflichen Kontext begleitet werden?",
    answer: "Ja. Das Angebot richtet sich an Unternehmen, Teams, Führungskräfte und Mitarbeitende, wenn das Anliegen beruflich eingeordnet ist.",
  },
  {
    question: "Wie startet eine Anfrage?",
    answer: "Über die Kontaktseite werden Anlass, Zielgruppe, gewünschter Schwerpunkt und Zeitraum per E-Mail beschrieben. Danach wird der passende nächste Schritt gemeinsam geklärt.",
  },
  {
    question: "Erbringt Competence Hub die Leistungen selbst?",
    answer: "Competence Hub klärt den Bedarf und vermittelt passende Coaches oder Expertinnen und Experten aus dem Netzwerk. Durchführung, Umfang und Rahmen werden anschließend transparent abgestimmt.",
  },
];
---

<BaseLayout
  title="Leistungen | Competence Hub"
  description="Competence Hub vermittelt Livecoaching, Businesscoaching, psychologische Beratung, Supervision, Workshops und Vorträge für Unternehmen."
>
  <main class="subpage">
    <section class="page-hero page-hero--accent">
      <p class="eyebrow">Leistungen</p>
      <h1>Das Thema zuerst. Dann die passende Expertise.</h1>
      <p>
        Competence Hub klärt den Bedarf und vermittelt ausgewählte Coaches
        oder Expertinnen und Experten. So finden Unternehmen einen passenden
        Einstieg, ohne sich zuerst durch einen großen Katalog arbeiten zu müssen.
      </p>
      <div class="actions">
        <a class="button" href={url("kontakt")}>Anfrage stellen</a>
        <a class="button button--ghost" href={url("unternehmen")}>Für Unternehmen</a>
      </div>
    </section>

    <section class="offer-grid" aria-label="Angebotsübersicht">
      {services.map((service) => (
        <article class="offer-card" id={service.id}>
          <p class="eyebrow">{service.eyebrow}</p>
          <h2>{service.title}</h2>
          <p>{service.text}</p>
          <a class="text-link" href={url(service.href)}>Mehr erfahren</a>
        </article>
      ))}
    </section>

    <section class="split-panel">
      <div>
        <p class="eyebrow">Einordnung</p>
        <h2>Welches Format passt zum Anliegen?</h2>
        <p>
          Die genaue Form wird im Erstkontakt geklärt. Wichtig ist zunächst,
          ob ein akuter beruflicher Anlass, eine breitere Entwicklungsfrage,
          psychologische Beratung oder ein Gruppenformat im Vordergrund steht.
        </p>
      </div>
      <div class="benefit-grid">
        {comparison.map((item) => (
          <span>
            {item.title}: {item.text}
          </span>
        ))}
      </div>
    </section>

    <section class="faq-section" aria-labelledby="services-faq-title">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2 id="services-faq-title">Häufige Fragen zu den Leistungen</h2>
      </div>
      <div class="faq-grid">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
