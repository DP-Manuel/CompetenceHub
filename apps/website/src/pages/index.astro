---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const offers = [
  {
    eyebrow: "Livecoaching",
    title: "Begleitung in echten Arbeitssituationen",
    text: "Livecoaching unterstützt Führungskräfte, Teams und Mitarbeitende dort, wo Kommunikation, Entscheidungen und Entwicklung konkret werden.",
    href: "livecoaching",
  },
  {
    eyebrow: "Businesscoaching",
    title: "Klarheit für Führung, Zusammenarbeit und Veränderung",
    text: "Businesscoaching schafft einen strukturierten Rahmen für berufliche Entwicklung, Konfliktklärung, Rollenverständnis und wirksame Führung.",
    href: "businesscoaching",
  },
  {
    eyebrow: "Für Unternehmen",
    title: "Angebote für Teams und Organisationen",
    text: "Unternehmen erhalten ein professionelles Angebot, das Ziele, Zielgruppen, Format und nächsten Schritt verständlich zusammenführt.",
    href: "unternehmen",
  },
  {
    eyebrow: "Coach-Netzwerk",
    title: "Passende Expertinnen und Experten einbinden",
    text: "Das Netzwerk kann später gezielt erweitert werden, damit Unternehmen passende Coaches für Thema, Zielgruppe und Format finden.",
    href: "coaches",
  },
];

const benefits = [
  "Livecoaching für konkrete berufliche Situationen",
  "Businesscoaching für Führung, Teams und Veränderung",
  "Klare Angebotsstruktur für Firmenkunden",
  "Wartbare Website-Basis für spätere Erweiterungen",
];

const audiences = [
  "Unternehmen, die Führung und Zusammenarbeit stärken wollen",
  "Teams, die Kommunikation, Rollen und Konflikte professionell bearbeiten möchten",
  "Führungskräfte und Mitarbeitende in beruflichen Entwicklungsphasen",
  "Coaches, die später Teil eines strukturierten Netzwerks werden können",
];
---

<BaseLayout
  title="Competence Hub | Livecoaching und Businesscoaching"
  description="Competence Hub bietet Livecoaching und Businesscoaching fuer Unternehmen, Teams und berufliche Entwicklung."
  bodyClass="home-page"
>
  <main>
    <section class="hero hero--competence">
      <div class="hero__copy">
        <p class="eyebrow">Competence Hub</p>
        <h1>Livecoaching und Businesscoaching für Unternehmen, Teams und berufliche Entwicklung.</h1>
        <p>
          Competence Hub bündelt professionelle Coaching-Angebote für
          Unternehmen, Führungskräfte und Teams. Der MVP fokussiert auf klare
          Angebote, verständliche Anfragewege und eine wartbare Website, die
          später um Buchung, Kalender und App-Funktionen erweitert werden kann.
        </p>
        <div class="actions">
          <a class="button" href={url("kontakt")}>Anfrage stellen</a>
          <a class="button button--ghost" href={url("leistungen")}>Angebote ansehen</a>
        </div>
      </div>
      <div class="hero-panel" aria-label="Competence Hub Angebotsschwerpunkte">
        <span>Website-MVP</span>
        <strong>Coaching-Angebote klar darstellen</strong>
        <div class="hero-panel__grid">
          <em>Livecoaching</em>
          <em>Businesscoaching</em>
          <em>Unternehmen</em>
          <em>Coach-Netzwerk</em>
        </div>
      </div>
    </section>

    <section class="offer-section" id="leistungen" aria-labelledby="offers-title">
      <div class="section-heading">
        <p class="eyebrow">Leistungen</p>
        <h2 id="offers-title">Vier Einstiegspunkte für den Website-MVP</h2>
      </div>
      <div class="offer-grid">
        {offers.map((offer) => (
          <article class="offer-card">
            <p class="eyebrow">{offer.eyebrow}</p>
            <h3>{offer.title}</h3>
            <p>{offer.text}</p>
            <a class="text-link" href={url(offer.href)}>Mehr erfahren</a>
          </article>
        ))}
      </div>
    </section>

    <section class="split-panel">
      <div>
        <p class="eyebrow">Was Competence Hub bietet</p>
        <h2>Ein klarer Rahmen für Coaching-Angebote, Anfragen und spätere Erweiterung</h2>
        <p>
          Die Website erklärt kompakt, welche Coaching-Formate angeboten
          werden, für welche Situationen sie passen und wie Unternehmen den
          nächsten Schritt anfragen können.
        </p>
      </div>
      <div class="benefit-grid">
        {benefits.map((benefit) => <span>{benefit}</span>)}
      </div>
    </section>

    <section class="audience-section" aria-labelledby="audience-title">
      <div class="section-heading">
        <p class="eyebrow">Zielgruppen</p>
        <h2 id="audience-title">Für wen ist das Angebot gedacht?</h2>
      </div>
      <div class="audience-list">
        {audiences.map((audience, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <p>{audience}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="future-note" aria-labelledby="future-title">
      <div>
        <p class="eyebrow">Ausbaustufen</p>
        <h2 id="future-title">Buchungssystem, Coach-Kalender und App kommen später</h2>
      </div>
      <p>
        Der aktuelle MVP verspricht keine produktive Buchung, keinen echten
        Login und keine Datenbank. Buchungssystem, Coach-Kalender,
        Vertragsautomatisierung und App-Funktionen bleiben bewusst spätere
        Ausbaustufen.
      </p>
    </section>
  </main>
</BaseLayout>
