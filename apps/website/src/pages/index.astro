---
import BaseLayout from "../layouts/BaseLayout.astro";
import CompetenceHubMap from "../components/CompetenceHubMap.astro";
import Icon from "../components/Icon.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const url = (path = "") => `${base}${path.replace(/^\//, "")}`;

const situations = [
  {
    title: "Führung wirksam gestalten",
    text: "Neue Verantwortung, schwierige Entscheidungen und anspruchsvolle Gespräche klar und reflektiert angehen.",
    icon: "leadership" as const,
    href: "businesscoaching",
  },
  {
    title: "Zusammenarbeit verbessern",
    text: "Rollen, Erwartungen und Kommunikation im Team sortieren, bevor Reibung dauerhaft Energie bindet.",
    icon: "users" as const,
    href: "livecoaching",
  },
  {
    title: "Konflikte früh klären",
    text: "Spannungen einordnen, Perspektiven zusammenbringen und tragfähige nächste Schritte entwickeln.",
    icon: "message-circle" as const,
    href: "livecoaching",
  },
  {
    title: "Belastung gesund begegnen",
    text: "Psychische Belastungen einordnen, Ressourcen stärken und Prävention im Arbeitsalltag verankern.",
    icon: "heart-pulse" as const,
    href: "leistungen",
  },
  {
    title: "Veränderung begleiten",
    text: "Orientierung geben, neue Rollen festigen und Mitarbeitende in beruflichen Übergängen stärken.",
    icon: "compass" as const,
    href: "businesscoaching",
  },
  {
    title: "Gesundheit in Bewegung bringen",
    text: "Gesundheitsförderung, Bewegung und Entspannung passend zum betrieblichen Kontext gestalten.",
    icon: "heart-pulse" as const,
    href: "leistungen",
  },
  {
    title: "Mitarbeitende gewinnen und entwickeln",
    text: "Potenziale erkennen, passende Menschen ansprechen und Personalentwicklung mit dem Unternehmensbedarf verbinden.",
    icon: "users" as const,
    href: "leistungen#recruiting",
  },
];

const formats = [
  {
    eyebrow: "Livecoaching",
    title: "Nah an der konkreten Situation",
    text: "Für aktuelle Gespräche, Entscheidungen, Konflikte oder Rollenfragen, bei denen zeitnah Klarheit entstehen soll.",
    href: "livecoaching",
    icon: "message-circle" as const,
  },
  {
    eyebrow: "Businesscoaching",
    title: "Entwicklung strukturiert begleiten",
    text: "Für Führungskräfte, Teams und Mitarbeitende, wenn Entwicklung, Zusammenarbeit oder Veränderung einen verlässlichen Rahmen braucht.",
    href: "businesscoaching",
    icon: "briefcase" as const,
  },
  {
    eyebrow: "Psychologische Beratung",
    title: "Belastungen professionell einordnen",
    text: "Für berufliche Fragestellungen, psychische Belastungen, Konflikte und gesundheitsbezogene Entwicklung im Unternehmen.",
    href: "leistungen",
    icon: "heart-pulse" as const,
  },
  {
    eyebrow: "Supervision & Workshops",
    title: "Teams und Wissen weiterbringen",
    text: "Für gemeinsame Reflexion, Prävention und konkrete Lernimpulse in Gruppen, Teams oder Fachveranstaltungen.",
    href: "leistungen",
    icon: "users" as const,
  },
  {
    eyebrow: "Recruiting & Personalentwicklung",
    title: "Menschen und Aufgaben passend verbinden",
    text: "Für Unternehmen, die Potenziale gezielter erkennen, Mitarbeitende gewinnen und Entwicklung mit dem tatsächlichen Bedarf verbinden möchten.",
    href: "leistungen#recruiting",
    icon: "building" as const,
  },
];

const trustPoints = [
  {
    text: "Ein Angebot von Donner + Partner",
    icon: "building" as const,
  },
  {
    text: "Ausgewählte Coaches",
    icon: "shield-check" as const,
  },
  {
    text: "Persönliche Bedarfsklärung",
    icon: "message-circle" as const,
  },
  {
    text: "Janay Rappelt als Ansprechpartnerin",
    icon: "user-round" as const,
  },
];

const process = [
  {
    title: "Bedarf verstehen",
    text: "Anlass, Zielgruppe und gewünschte Wirkung werden im Erstkontakt gemeinsam eingeordnet.",
  },
  {
    title: "Passende Expertise auswählen",
    text: "Aus Thema, Situation und Rahmen entsteht eine begründete Empfehlung aus dem Coach-Netzwerk.",
  },
  {
    title: "Nächsten Schritt vereinbaren",
    text: "Umfang, Termin und Vorgehen werden transparent abgestimmt, bevor das Coaching startet.",
  },
  {
    title: "Umsetzung begleiten",
    text: "Janay Rappelt bleibt als persönliche Verbindung zwischen Unternehmen und Coach ansprechbar.",
  },
];

const coachPreview = [
  {
    name: "Christian Galvano",
    role: "Führung, Konflikte & Prävention",
    href: "coaches/christian-galvano",
    image: "images/coaches/christian-galvano.webp",
    initials: "CG",
  },
  {
    name: "Elisabeth Schwabauer",
    role: "Psychologie, Belastung & Teams",
    href: "coaches/elisabeth-schwabauer",
    initials: "ES",
  },
  {
    name: "Carolin Hupp",
    role: "Gesundheit, Bewegung & Prävention",
    href: "coaches/carolin-hupp",
    initials: "CH",
  },
  {
    name: "Wegner-Ney",
    role: "Führung, Teams & Recruiting",
    href: "coaches/wegner-ney",
    image: "images/coaches/wegner-ney.jpg",
    initials: "WN",
  },
];
---

<BaseLayout
  title="Competence Hub | Passende Coaches für Unternehmen"
  description="Competence Hub verbindet Unternehmensanliegen mit ausgewählten Coaches und passenden Formaten für Führung, Teams, Recruiting, Gesundheit und Entwicklung."
  bodyClass="home-page"
>
  <main>
    <section class="hub-hero" aria-label="Competence Hub entdecken">
      <CompetenceHubMap />
    </section>

    <section class="trust-strip" aria-label="Competence Hub auf einen Blick">
      {trustPoints.map((point) => (
        <article>
          <Icon name={point.icon} size={24} />
          <strong>{point.text}</strong>
        </article>
      ))}
    </section>

    <section class="situation-section" id="einsatzfelder" aria-labelledby="situations-title">
      <div class="section-heading">
        <p class="eyebrow">Typische Anlässe</p>
        <h2 id="situations-title">Welches Thema interessiert Sie?</h2>
      </div>
      <div class="situation-grid">
        {situations.map((situation) => (
          <details class="situation-card">
            <summary>
              <Icon name={situation.icon} size={28} />
              <span>{situation.title}</span>
              <span class="situation-card__toggle" aria-hidden="true">+</span>
            </summary>
            <div class="situation-card__details">
              <p>{situation.text}</p>
              <a class="text-link" href={url(situation.href)}>Passende Angebote</a>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section class="format-band" aria-labelledby="formats-title">
      <div>
        <p class="eyebrow">Leistungsspektrum</p>
        <h2 id="formats-title">Das Thema zuerst. Dann die passende Expertise.</h2>
        <p>Sie bringen das Anliegen. Wir empfehlen Expertise und Format.</p>
      </div>
      <div class="format-grid">
        {formats.map((format) => (
          <article>
            <p class="eyebrow">{format.eyebrow}</p>
            <Icon name={format.icon} size={30} />
            <h3>{format.title}</h3>
            <details class="format-details">
              <summary>Mehr erfahren</summary>
              <p>{format.text}</p>
            </details>
            <a class="text-link" href={url(format.href)}>Zum Angebot</a>
          </article>
        ))}
      </div>
    </section>

    <section class="process-section" id="so-funktioniert-der-hub" aria-labelledby="process-title">
      <div class="section-heading">
        <p class="eyebrow">So verbindet der Hub</p>
        <h2 id="process-title">Ein Anliegen. Die passende Verbindung.</h2>
      </div>
      <div class="timeline-list timeline-list--compact">
        {process.map((step, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="coach-preview" aria-labelledby="coach-spotlight-title">
      <div class="coach-preview__heading">
        <div>
          <p class="eyebrow">Kuratiertes Coach-Netzwerk</p>
          <h2 id="coach-spotlight-title">Expertise hat ein Gesicht</h2>
        </div>
        <p>Qualifikation, Schwerpunkte und Einsatzbereich auf einen Blick.</p>
      </div>
      <div class="coach-preview__grid">
        {coachPreview.map((coach) => (
          <a class="coach-preview__card" href={url(coach.href)}>
            <span class:list={["coach-preview__visual", { "coach-preview__visual--image": coach.image }]}>
              {coach.image ? (
                <img
                  src={url(coach.image)}
                  alt={`Porträt von ${coach.name}`}
                  width="830"
                  height="830"
                  loading="lazy"
                />
              ) : (
                <strong aria-hidden="true">{coach.initials}</strong>
              )}
            </span>
            <span class="coach-preview__copy">
              <strong>{coach.name}</strong>
              <small>{coach.role}</small>
            </span>
          </a>
        ))}
      </div>
      <a class="text-link" href={url("coaches")}>Alle Coach-Profile ansehen</a>
    </section>

    <section class="contact-lead" id="anfrage" aria-labelledby="contact-lead-title">
      <div class="contact-lead__person">
        <span aria-hidden="true"><Icon name="user-round" size={34} /></span>
        <div>
          <small>Ihre Ansprechpartnerin</small>
          <strong>Janay Rappelt</strong>
          <p>Persönliche Verbindung zwischen Unternehmen und Coaches</p>
        </div>
      </div>
      <div class="contact-lead__copy">
        <p class="eyebrow">Nächster Schritt</p>
        <h2 id="contact-lead-title">Wobei dürfen wir Sie unterstützen?</h2>
        <p>Eine kurze Beschreibung reicht für die erste Einordnung.</p>
        <a class="button" href={url("kontakt")}>Bedarf besprechen</a>
      </div>
    </section>
  </main>
</BaseLayout>
