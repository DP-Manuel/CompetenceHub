# Copy this file to .env only when the future backend is initialized.
# Never commit the real .env file or add real credentials here.

APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=3000

# MySQL/MariaDB is the current assumption and must be verified on the server.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=competence_hub
DB_USER=competence_hub_app
DB_PASSWORD=
DB_SSL_MODE=preferred

# Server access metadata. SSH passwords do not belong in this file.
SERVER_HOST=
SERVER_PORT=22
SERVER_USER=
SSH_KEY_PATH=
